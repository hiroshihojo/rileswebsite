{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "subcategory": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "sortDate": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "imageAlt": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "intro": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "format": {
      "default": "standard",
      "type": "string",
      "enum": [
        "standard",
        "photo-series"
      ]
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "category",
    "author",
    "date",
    "sortDate",
    "image",
    "imageAlt",
    "excerpt",
    "intro"
  ]
}