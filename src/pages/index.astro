---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const bySlug = (slug: string) => allArticles.find((a) => a.id === slug)!;

// Primary + secondary featured posts (curated, mirrors original design)
const primary = bySlug('bayanihan');
const secondary = [bySlug('filipiniana'), bySlug('trenko')];

// All possible categories, in display order. Only ones with at least
// one article will actually render below.
const allCategories = ['Radar', 'Culture', 'Art & Design', 'Music & Film', 'Fashion', 'Gaming'];
const categoryGroups = allCategories
  .map((label) => ({
    label,
    id: label.toLowerCase().replace(/\s*&\s*/g, '-').replace(/\s+/g, '-'),
    posts: allArticles.filter((a) => a.data.category === label),
  }))
  .filter((group) => group.posts.length > 0);
---

<BaseLayout title="Riles Magazine" active="home">
    <main class="content-wrapper">
        <section class="featured-grid">
            <!-- Primary Featured Post -->
            <a href={`/articles/${primary.id}`} class="featured-post primary" style="text-decoration: none; color: inherit;">
                <img src={primary.data.image} alt={primary.data.imageAlt}>
                <div class="featured-content">
                    <span class="category-tag">{primary.data.category}</span>
                    <h2>{primary.data.title}</h2>
                    <p class="excerpt">{primary.data.excerpt}</p>
                    <p class="meta">{primary.data.author} · {primary.data.date}</p>
                </div>
            </a>

            <!-- Secondary Featured Posts -->
            <div class="secondary-grid">
                {secondary.map((post) => (
                    <a href={`/articles/${post.id}`} class="featured-post secondary">
                        <img src={post.data.image} alt={post.data.imageAlt}>
                        <div class="featured-content">
                            <span class="category-tag">{post.data.category}</span>
                            <h3>{post.data.title}</h3>
                            <p class="meta">{post.data.author} · {post.data.date}</p>
                        </div>
                    </a>
                ))}
            </div>

            <!-- MEDIA GRID - Instagram + Spotify -->
            <div class="media-grid">
                <section class="media-section instagram-section">
                    <h2 class="section-title">If you haven't seen it yet</h2>
                    <div class="instagram-embed-container">
                        <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/p/DVu_E-okVby/?utm_source=ig_web_copy_link&igsh=MzRlODBiNWFlZA==" data-instgrm-version="14"></blockquote>
                        <script async src="//www.instagram.com/embed.js"></script>
                    </div>
                </section>

                <section class="media-section spotify-section">
                    <h2 class="section-title">Riles Radio</h2>
                    <div class="spotify-embed-container">
                        <iframe
                            style="border-radius:12px"
                            src="https://open.spotify.com/embed/playlist/2vledWtMQNAzyo6WlH7zKp?utm_source=generator&theme=0"
                            width="100%"
                            height="352"
                            frameborder="0"
                            allowfullscreen
                            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                            loading="lazy">
                        </iframe>
                    </div>
                </section>
            </div>

            <!-- CATEGORIES GRID -->
            <div class="categories-grid" data-count={categoryGroups.length}>
                {categoryGroups.map((group) => (
                    <section class="category-section" id={group.id}>
                        <h2 class="section-title">{group.label}</h2>
                        <div class="category-grid">
                            {group.posts.map((post) => (
                                <a href={`/articles/${post.id}`} class="category-post">
                                    <img src={post.data.image} alt={post.data.imageAlt}>
                                    <h3>{post.data.title}</h3>
                                </a>
                            ))}
                        </div>
                    </section>
                ))}
            </div>
        </section>
    </main>

    <!-- TEAM SIGNUP BOTTOM BANNER -->
    <section class="team-signup-banner" style="background-image: url('/TEAM-WIDGET-BG.jpg'); background-size: cover; background-position: center;">
        <div class="banner-content">
            <h2>Become a staffer</h2>
            <p>Help us shape Riles Magazine.</p>
            <a href="https://forms.gle/YVAgXaLf1zY8Mfwx8" class="signup-button">SIGN UP</a>
        </div>
    </section>
</BaseLayout>
