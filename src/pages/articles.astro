---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/articles.css';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('articles')).sort(
  (a, b) => b.data.sortDate.valueOf() - a.data.sortDate.valueOf()
);

const categories = [
  { id: 'radar', label: 'Radar' },
  { id: 'culture', label: 'Culture' },
  { id: 'art-design', label: 'Art & Design' },
  { id: 'music-film', label: 'Music & Film' },
  { id: 'fashion', label: 'Fashion' },
  { id: 'gaming', label: 'Gaming' },
];

const bySlugId = (label: string) => label.toLowerCase().replace(/\s*&\s*/g, '-').replace(/\s+/g, '-');
const articlesByCategory = (id: string) =>
  allArticles.filter((a) => bySlugId(a.data.category) === id);
---

<BaseLayout title="Articles – Riles Magazine" active="articles">
    <main class="articles-page">

        <div class="articles-hero">
            <h1><strong>Articles</strong></h1>
            <p class="articles-subtitle">This is a space where we look at the now and next of our culture.</p>
        </div>

        <div class="articles-controls">
            <div class="category-filters">
                <button class="filter-btn active" data-filter="all">All</button>
                {categories.filter((c) => articlesByCategory(c.id).length > 0).map((c) => (
                    <button class="filter-btn" data-filter={c.id}>{c.label}</button>
                ))}
            </div>
            <div class="articles-search-wrap">
                <input type="text" id="articleSearch" placeholder="Search articles…" aria-label="Search articles">
            </div>
        </div>

        <section id="all-articles">
            <p class="articles-section-label">All Articles</p>
            <div class="editorial-list" id="editorialList">
                {allArticles.map((a) => (
                    <a
                        href={`/articles/${a.id}`}
                        class="editorial-card"
                        data-cats={bySlugId(a.data.category)}
                        data-title={a.data.title.toLowerCase()}
                    >
                        <img src={a.data.image} alt={a.data.imageAlt}>
                        <h3>{a.data.title}</h3>
                        <p class="card-excerpt">{a.data.excerpt}</p>
                        <div class="card-meta">
                            <span class="card-date">{a.data.date}</span>
                            <span class="card-cat">{a.data.category}</span>
                        </div>
                    </a>
                ))}
            </div>

            <p class="no-results" id="noResults">No articles found. Try a different search or filter.</p>
        </section>

        {categories.map((c) => {
            const items = articlesByCategory(c.id);
            if (items.length === 0) return null;
            return (
                <section class="cat-section" id={`cat-${c.id}`} data-category={c.id}>
                    <div class="cat-section-header">
                        <h2>{c.label}</h2>
                        <a href={`#cat-${c.id}`} class="see-all">See all →</a>
                    </div>

                    {items.map((a) => (
                        <div class="cat-sub-grid">
                            <a href={`/articles/${a.id}`} class="cat-sub-card">
                                <img src={a.data.image} alt={a.data.imageAlt}>
                                <span class="sub-date">{a.data.date}</span>
                                <h4>{a.data.title}</h4>
                            </a>
                        </div>
                    ))}
                </section>
            );
        })}

    </main>
</BaseLayout>

<script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const allCards = document.querySelectorAll<HTMLElement>('.editorial-card');
    const catSections = document.querySelectorAll<HTMLElement>('.cat-section');
    const noResults = document.getElementById('noResults');
    const searchInput = document.getElementById('articleSearch') as HTMLInputElement | null;

    function applyFilters() {
        const activeBtn = document.querySelector<HTMLButtonElement>('.filter-btn.active');
        const activeFilter = activeBtn?.dataset.filter ?? 'all';
        const query = (searchInput?.value ?? '').toLowerCase().trim();

        let visibleCount = 0;

        allCards.forEach((card) => {
            const cats = card.dataset.cats || '';
            const title = card.dataset.title || '';
            const catMatch = activeFilter === 'all' || cats.includes(activeFilter);
            const textMatch = !query || title.includes(query);

            if (catMatch && textMatch) {
                card.classList.remove('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });

        if (noResults) {
            noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }

        catSections.forEach((section) => {
            const scat = section.dataset.category || '';
            const catMatch = activeFilter === 'all' || scat === activeFilter;
            section.style.display = catMatch ? '' : 'none';
        });
    }

    filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
            filterBtns.forEach((b) => b.classList.remove('active'));
            btn.classList.add('active');
            applyFilters();
        });
    });

    searchInput?.addEventListener('input', applyFilters);
</script>
